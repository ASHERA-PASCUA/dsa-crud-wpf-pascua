<Window x:Class="midterms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:midterms"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FFCDF9FF">

        <DataGrid x:Name="Menu"
                  ItemsSource="{Binding Products}"
                  AutoGenerateColumns="False"
                  Margin="10,41,10,271"
                  Background="White" SelectionChanged="Menu_SelectionChanged">


            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID" Binding="{Binding Productid}" Width="*"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding Productname}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Descriptions}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Prices}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Add"
                HorizontalAlignment="Left"
                Height="19"
                Margin="116,386,0,0"
                VerticalAlignment="Top"
                Width="76"
                Background="#FFFF84A0"
                FontFamily="Palatino Linotype"
                Click="Add_Click"/>
        <DataGrid x:Name="Menu_Copy"
            ItemsSource="{Binding Employees}"
            AutoGenerateColumns="False"
            Margin="10,205,10,108"
            Background="White">


            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="*"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock HorizontalAlignment="Left" Margin="328,175,0,0" TextWrapping="Wrap" Text="Shopping Cart Section" VerticalAlignment="Top" FontWeight="Bold"/>
        <TextBlock HorizontalAlignment="Left" Margin="343,13,0,0" TextWrapping="Wrap" Text="Available Products" VerticalAlignment="Top" FontWeight="Bold"/>
        <Button Content="Remove"
            HorizontalAlignment="Left"
            Height="19"
            Margin="197,386,0,0"
            VerticalAlignment="Top"
            Width="76"
            Background="#FFFF84A0"
            FontFamily="Palatino Linotype"
            Click="Add_Click"/>
        <Button Content="Add to Cart"
            HorizontalAlignment="Left"
            Height="19"
            Margin="278,386,0,0"
            VerticalAlignment="Top"
            Width="76"
            Background="#FFFF84A0"
            FontFamily="Palatino Linotype"
            Click="Add_Click"/>
        <Button Content="Clear"
            HorizontalAlignment="Left"
            Height="19"
            Margin="359,386,0,0"
            VerticalAlignment="Top"
            Width="76"
            Background="#FFFF84A0"
            FontFamily="Palatino Linotype"
            Click="Add_Click"/>
        <TextBox HorizontalAlignment="Left" Height="22" Margin="96,351,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="87"/>
        <TextBox HorizontalAlignment="Left" Height="22" Margin="231,351,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="124"/>
        <TextBox HorizontalAlignment="Left" Height="22" Margin="440,351,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="111"/>
        <TextBox HorizontalAlignment="Left" Height="23" Margin="594,351,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="87"/>
        <TextBlock HorizontalAlignment="Left" Height="44" Margin="77,351,0,0" TextWrapping="Wrap" Text="ID:" VerticalAlignment="Top" Width="21" FontSize="15"/>
        <TextBlock HorizontalAlignment="Left" Height="44" Margin="187,350,0,0" TextWrapping="Wrap" Text="Name:" VerticalAlignment="Top" Width="43" FontSize="15"/>
        <TextBlock HorizontalAlignment="Center" Height="44" Margin="0,351,0,0" TextWrapping="Wrap" Text="Description:" VerticalAlignment="Top" Width="80" FontSize="15"/>
        <TextBlock HorizontalAlignment="Left" Height="44" Margin="557,353,0,0" TextWrapping="Wrap" Text="Price:" VerticalAlignment="Top" Width="43" FontSize="15"/>


    </Grid>
</Window>
